# BlindBase Server Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Server-side encryption key (32 bytes = 64 hex characters)
# Generate with: php -r "echo bin2hex(sodium_crypto_secretbox_keygen());"
# IMPORTANT: Keep this secret! If lost, all data becomes unrecoverable.
BLINDBASE_SECRET=

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Storage directory path (default: ./storage/)
# Must be writable by the web server
# BLINDBASE_STORAGE_PATH=./storage/

# Maximum payload size in MB (default: 10)
# BLINDBASE_MAX_PAYLOAD_MB=10

# Allowed CORS origins (comma-separated)
# Leave empty to allow all origins (development only!)
# Example: https://myapp.com,https://www.myapp.com
# BLINDBASE_ALLOWED_ORIGINS=
